---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import GoogleContactForm from '~/components/widgets/GoogleContactForm.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = {
  title: 'Contact Support | Schedule Makeup',
  description: 'Have questions about the lifetime deal for your makeup studio? Contact our team today.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroText 
    tagline="We're in your corner ⭐⭐⭐⭐⭐"
    title="Let's Talk About Your Studio." 
    subtitle="Have questions about the lifetime deal? Need a bulk discount for multiple makeup artists? We respond faster than a setting spray dries."
  />
  <GoogleContactForm />
  <Features
    class="-mt-16"
    columns={3}
    items={[
      { title: 'Studio Discounts', description: 'Running a large studio? Contact us for custom bulk pricing on 3+ artists.', icon: 'tabler:building-store' },
      { title: 'White-Glove Support', description: 'Need help with your booking widget? We are here to help.', icon: 'tabler:headset' },
      { title: 'Partnerships', description: 'Are you a beauty consultant? Let’s work together.', icon: 'tabler:users' },
    ]}
  />
  <Hero class="-mt-16" image={{ src: '/images/testimonial-7.webp', alt: 'Schedule Makeup happy client' }} />
</Layout>
