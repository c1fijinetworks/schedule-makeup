---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Terms of Service | Schedule.Makeup' };
---
<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-8">Terms of Service</h1>
    <div class="prose prose-lg max-w-4xl dark:prose-invert">
      <p>Welcome to <strong>Schedule.Makeup</strong>. By using our services, you agree to these terms.</p>
      <h3>1. Service</h3>
      <p>We provide vanity URLs (yourname.schedule.makeup) and boutique booking setups for Makeup Artists.</p>
      <h3>2. Payments</h3>
      <p>The $99 fee is a one-time setup fee for lifetime access to the configured vanity URL service.</p>
    </div>
  </section>
</Layout>
