---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Privacy Policy | Schedule.Makeup' };
---
<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-8">Privacy Policy</h1>
    <div class="prose prose-lg max-w-4xl dark:prose-invert">
      <p>At <strong>Schedule.Makeup</strong>, your privacy is a priority. We collect only necessary data to setup your professional studio booking page.</p>
    </div>
  </section>
</Layout>
