---
import Hero from '~/components/widgets/Hero.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = {
  title: 'Our Mission - Schedule.Makeup | Built for Artists',
  description: 'We built Schedule.Makeup because makeup is art, but business is about trust. Learn how we help artists dominate Google search.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
<Hero2
    tagline="The Professional Standard ⭐⭐⭐⭐⭐"
    title='You Create the Art.<br/><span class="text-accent dark:text-white">We Build Your Digital Handshake.</span>'
    subtitle="Elite artists lose clients to generic booking links. We ensure your digital presence matches your talent. No monthly fees—just a professional, automated system to keep your books full."
     
    image={{ src: '/images/testimonial-5.webp', alt: 'Makeup Studio Hero' }}
    actions={[
      { variant: 'primary', text: 'Claim My Lifetime Access - $99', href: '/pricing/' },
    ]}
  />

  <Content
    isReversed
    items={[
        { title: 'The Premium First Impression', description: 'When a client clicks "Schedule" on Google, they should see your brand, not a spreadsheet. Our vanity URLs provide instant elite status.', icon: 'tabler:sparkles' },
        { title: 'Local Search SEO', description: 'Google prioritizes studios with high-quality, branded links. Our schedule.makeup domains signal to Google that you are an established local pro.', icon: 'tabler:map-pin' },
        { title: 'Zero Friction Booking', description: 'Our mobile-first UX is optimized for clients booking glam on the go, preventing client drop-off.', icon: 'tabler:users' },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Why your studio needs <span class="text-accent">A Professional Vanity URL ⭐⭐⭐⭐⭐</span>
      </h3>
      <p>Clients look at screens, not storefronts. Your URL is your digital handshake—we make sure yours is a 5-star introduction.</p>
    </Fragment>
    <Fragment slot="image">
       <img src="/images/testimonial-4.webp" alt="Elite makeup studio experience" class="rounded-lg shadow-xl w-full" />
    </Fragment>
  </Content>

  <Content
    items={[
      { title: 'Zero Maintenance', description: 'We know you’re busy with back-to-back bookings. Once we set up your vanity URL, you never have to log in or "manage" anything technical.', icon: 'tabler:settings' },
      { title: 'White-Glove Integration', description: 'We handle the Google Business Profile link setup for you, ensuring your "Schedule" button points exactly where it should.', icon: 'tabler:stars' },
      { title: 'One-Time Payment', description: 'We don’t believe in monthly fees that eat your profits. $99 once, and you own the system for life.', icon: 'tabler:coin' },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
        Our Commitment to Your Success
      </h2>
      <p class="text-xl text-muted dark:text-slate-400 mb-8">
        We aren't just another software company. We are a partner in your growth. We handle the technical hurdles so you can stay focused on your artistry.
      </p>
    </Fragment>
    <Fragment slot="image">
      <img src="/images/testimonial-3.webp" alt="Makeup professional managing bookings" class="rounded-lg shadow-xl w-full" />
    </Fragment>
  </Content>

  <Pricing
    class="pb-0"
    title={`<span class="text-accent dark:text-white">Invest in Your Professional Future.</span>`}
    prices={[lifetimeDeal]}
  />

  <Hero class="-mt-16">
    <Fragment slot="image">
      <img src="/images/testimonial-6.webp" alt="A professional glam booking interface" class="mx-auto rounded-md w-full shadow-lg" loading="lazy" />
    </Fragment>
  </Hero>
</Layout>
