---
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Layout from '~/layouts/PageLayout.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { headerData } from '~/navigation';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { 
  title: 'Our Mission | Schedule.Makeup', 
  description: 'Why your studio deserves a professional vanity URL and a high-end booking experience.' 
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="The Professional Standard"
    title='More Than Just a <span class="text-accent">Schedule Button</span>'
    subtitle="When a client sees your studio on Google, that 'Schedule' button is their first point of contact. We ensure that click leads to a premium branded experience."
    actions={[{ variant: 'primary', text: 'Secure My URL', href: '/pricing/' }]}
    image={{ src: '/images/hero-poster.webp', alt: 'Schedule.Makeup Professional Branding' }}
  />
  
  <Content
    isReversed
    items={[
        { title: 'Custom Studio Branding', description: 'No generic logos. Your booking page is 100% focused on YOUR artistry.', icon: 'tabler:check' },
        { title: 'Mobile-First Speed', description: 'Load times are optimized for clients booking glam on the go.', icon: 'tabler:device-mobile' },
        { title: 'Google SEO Signal', description: 'Custom URLs indexed by Google help your studio climb local rankings.', icon: 'tabler:rocket' },
        { title: 'Zero Distractions', description: 'We keep the client focused on your availability, not competitors.', icon: 'tabler:eye-off' },
        { title: 'Trust & Credibility', description: 'A custom schedule.makeup domain signals you are an elite professional.', icon: 'tabler:shield-check' },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-3xl font-bold mb-4">Stand Out in the Beauty Industry</h3>
      <p class="text-lg text-muted">In the modern makeup industry, your digital handshake is your URL. We provide the polish your studio deserves.</p>
    </Fragment>
    <Fragment slot="image">
       <img src="/images/testimonial-4.webp" alt="Elite makeup studio" class="rounded-lg shadow-xl w-full" />
    </Fragment>
  </Content>

  <Pricing title="Ready to Own Your Professional Identity?" prices={[lifetimeDeal]} />
</Layout>
